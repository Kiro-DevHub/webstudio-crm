generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

enum ClientSource {
  WEBSITE
  REFERRAL
  SOCIAL
  COLD
  OTHER
}

enum DealStage {
  LEAD
  BRIEF
  PROPOSAL
  CONTRACT
  IN_PROGRESS
  DELIVERY
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ActivityType {
  DEAL_CREATED
  STAGE_CHANGED
  TASK_CREATED
  TASK_COMPLETED
  NOTE_ADDED
  CLIENT_CREATED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  role             Role     @default(MANAGER)
  avatarColor      String
  isActive         Boolean  @default(true)
  /// SHA-256 hex digest of the currently active refresh token; null when logged out.
  refreshTokenHash String?
  createdAt        DateTime @default(now()) @db.Timestamptz(3)

  clients    Client[]
  deals      Deal[]
  tasks      Task[]
  activities Activity[]
  notes      Note[]

  @@map("users")
}

model Client {
  id          String       @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String
  source      ClientSource
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)

  deals      Deal[]
  activities Activity[]

  @@index([ownerId])
  @@index([createdAt])
  @@map("clients")
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  /// Amount in kopecks (minor units), never floats.
  amount            Int
  stage             DealStage @default(LEAD)
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ownerId           String
  owner             User      @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  expectedCloseDate DateTime  @db.Timestamptz(3)
  closedAt          DateTime? @db.Timestamptz(3)
  lostReason        String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(3)

  tasks      Task[]
  activities Activity[]
  notes      Note[]

  @@index([stage, createdAt])
  @@index([clientId])
  @@index([ownerId])
  @@index([createdAt])
  @@index([closedAt])
  @@map("deals")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime   @db.Timestamptz(3)
  dealId      String?
  deal        Deal?      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User       @relation(fields: [assigneeId], references: [id], onDelete: Restrict)
  createdAt   DateTime   @default(now()) @db.Timestamptz(3)

  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([dealId])
  @@map("tasks")
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  /// Event details, e.g. { "from": "LEAD", "to": "BRIEF" } for STAGE_CHANGED.
  payload   Json         @default("{}")
  dealId    String?
  deal      Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt DateTime     @default(now()) @db.Timestamptz(3)

  @@index([dealId, createdAt])
  @@index([clientId, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Note {
  id        String   @id @default(cuid())
  body      String
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([dealId, createdAt])
  @@index([authorId])
  @@map("notes")
}
