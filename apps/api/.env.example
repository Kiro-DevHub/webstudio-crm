PORT=3000

POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm
POSTGRES_PORT=5432
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm

# JWT (use long random strings in production, e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# NODE_ENV is intentionally NOT set here — it must come from the runtime, not .env.
# It controls the refresh-cookie attributes (see src/modules/auth/auth.constants.ts):
#   unset / anything else -> SameSite=Lax, no Secure (works on plain-http localhost)
#   production            -> SameSite=None; Secure (required for the cross-site
#                            web app on another domain; needs HTTPS)
# The API Dockerfile and Render already set NODE_ENV=production.
