# Copy to .env.prod and fill in real values before running docker-compose.prod.yml.
# NEVER commit .env.prod.

POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=crm

# openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Domain Caddy requests a TLS certificate for and proxies to the api container.
# For a local smoke test of the prod stack, use "localhost" (Caddy serves HTTPS
# with its internal CA instead of requesting a public certificate).
API_DOMAIN=api.your-domain.com

# Comma-separated allow-list of origins the API accepts credentialed requests from —
# the web app's deployed URL(s). Must share a registrable domain with API_DOMAIN
# for the sameSite=strict refresh cookie to be sent (e.g. app.your-domain.com + api.your-domain.com).
CORS_ORIGIN=https://app.your-domain.com
